{
    "name": "TradeSimulator Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "forwardPorts": [8080],
    "postStartCommand": "echo 'Dev container ready! Run mvn spring-boot:run to start the app.'",
    "customizations": {
        "vscode": {
            "settings": {
                "java.configuration.runtimes": [
                    {
                        "name": "JavaSE-17",
                        "path": "/usr/lib/jvm/java-17-openjdk",
                        "default": true
                    }
                ]
            },
            "extensions": [
                "vscjava.vscode-java-pack",
                "redhat.java",
                "pivotal.vscode-spring-boot"
            ]
        }
    },
    "remoteUser": "root"
}